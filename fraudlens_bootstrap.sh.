#!/usr/bin/env python3
"""
FraudLens CCTV Analyzer v1.0
Motion detection and activity timeline from CCTV footage
"""
import cv2, numpy as np, json, os, sys, glob, re
from datetime import datetime
from tqdm import tqdm

OUTPUT_DIR = "/home/ubuntu/fraudlens/results"
os.makedirs(OUTPUT_DIR, exist_ok=True)

def analyze(video_path):
    cap = cv2.VideoCapture(video_path)
    if not cap.isOpened():
        print(f"ERROR: Cannot open {video_path}")
        return None

    fps      = cap.get(cv2.CAP_PROP_FPS)
    total    = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    width    = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    height   = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    duration = total / fps if fps > 0 else 0

    print(f"\n{'═'*55}")
    print(f"  FRAUDLENS ANALYZER — {os.path.basename(video_path)}")
    print(f"{'═'*55}")
    print(f"  Resolution : {width}x{height} | FPS: {fps:.2f}")
    print(f"  Duration   : {duration/60:.1f} min ({total} frames)")
    print(f"{'─'*55}")

    bg_sub       = cv2.createBackgroundSubtractorMOG2(
                       history=500, varThreshold=50, detectShadows=False)
    sample_every = max(1, int(fps))
    activity_log = []
    high_count   = 0
    frame_idx    = 0

    with tqdm(total=total // sample_every, unit='sec',
              desc="  Scanning") as pbar:
        while cap.isOpened():
            ret, frame = cap.read()
            if not ret:
                break
            if frame_idx % sample_every == 0:
                fg         = bg_sub.apply(frame)
                motion_pct = round(np.count_nonzero(fg) / (width * height) * 100, 2)
                ts         = frame_idx / fps
                level      = ("HIGH"   if motion_pct > 5  else
                              "MEDIUM" if motion_pct > 1  else "LOW")
                if motion_pct > 5:
                    high_count += 1
                activity_log.append({
                    "second"    : int(ts),
                    "timestamp" : f"{int(ts//60):02d}:{int(ts%60):02d}",
                    "motion_pct": motion_pct,
                    "activity"  : level
                })
                pbar.update(1)
            frame_idx += 1
    cap.release()

    scores   = [e["motion_pct"] for e in activity_log]
    top10    = sorted(activity_log, key=lambda x: x["motion_pct"], reverse=True)[:10]
    base     = os.path.splitext(os.path.basename(video_path))[0]

    result = {
        "file"         : os.path.basename(video_path),
        "processed_at" : datetime.now().isoformat(),
        "video_info"   : {
            "resolution"   : f"{width}x{height}",
            "fps"          : round(fps, 2),
            "duration_min" : round(duration / 60, 1),
            "total_frames" : total
        },
        "summary" : {
            "avg_motion"        : round(np.mean(scores), 2),
            "max_motion"        : round(np.max(scores), 2),
            "high_activity_pct" : round(high_count / len(scores) * 100, 1),
            "busiest_moments"   : top10
        },
        "timeline" : activity_log
    }

    out = os.path.join(OUTPUT_DIR, f"{base}.json")
    with open(out, "w") as f:
        json.dump(result, f, indent=2)

    print(f"\n  {'─'*51}")
    print(f"  SUMMARY")
    print(f"  {'─'*51}")
    print(f"  Avg motion    : {result['summary']['avg_motion']}%")
    print(f"  Peak motion   : {result['summary']['max_motion']}%")
    print(f"  High activity : {result['summary']['high_activity_pct']}% of footage")
    print(f"\n  Top 5 busiest moments:")
    for m in top10[:5]:
        print(f"    {m['timestamp']}  →  {m['motion_pct']}%  [{m['activity']}]")
    print(f"\n  ✓ Results saved → {out}")
    print(f"  {'═'*51}\n")
    return result

if __name__ == "__main__":
    if len(sys.argv) > 1:
        videos = sys.argv[1:]
    else:
        videos = (glob.glob("/home/ubuntu/fraudlens/processed/*.mp4") +
                  glob.glob("/home/ubuntu/fraudlens/raw/*.mp4"))
    if not videos:
        print("No videos found. Upload to /home/ubuntu/fraudlens/raw/")
        sys.exit(1)
    for v in videos:
        analyze(v)
PYEOF
