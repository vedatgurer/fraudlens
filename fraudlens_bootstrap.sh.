#!/usr/bin/env python3
"""
FraudLens Filename Normalizer
Converts: "16.03.2026 00,05-02,37 Emin Bekçi.mp4"
To:       "FRAUDLENS_16.03.2026_0005-0237_Emin_Bekci.mp4"
"""
import os, re, shutil, sys

TR_MAP = str.maketrans(
    'çşığöüÇŞİĞÖÜ',
    'csigouCSIGOU'
)

def normalize(original):
    name = os.path.splitext(os.path.basename(original))[0]
    date_m = re.search(r'(\d{2}\.\d{2}\.\d{4})', name)
    date   = date_m.group(1) if date_m else 'UNKNOWN'
    time_m = re.search(r'(\d{2}),(\d{2})-(\d{2}),(\d{2})', name)
    trange = f"{time_m.group(1)}{time_m.group(2)}-{time_m.group(3)}{time_m.group(4)}" \
             if time_m else 'UNKNOWN'
    loc    = re.sub(r'.*\d{2},\d{2}-\d{2},\d{2}\s*', '', name).strip()
    loc    = loc.translate(TR_MAP).replace(' ', '_')
    return f"FRAUDLENS_{date}_{trange}_{loc}.mp4"

def process_folder(raw_dir, processed_dir):
    files = [f for f in os.listdir(raw_dir) if f.endswith('.mp4')]
    if not files:
        print("No .mp4 files found in raw/")
        return []
    renamed = []
    for f in files:
        new_name = normalize(f)
        src = os.path.join(raw_dir, f)
        dst = os.path.join(processed_dir, new_name)
        shutil.move(src, dst)
        print(f"  {f}")
        print(f"  → {new_name}\n")
        renamed.append(dst)
    return renamed

if __name__ == "__main__":
    raw  = sys.argv[1] if len(sys.argv) > 1 else "/home/ubuntu/fraudlens/raw"
    proc = sys.argv[2] if len(sys.argv) > 2 else "/home/ubuntu/fraudlens/processed"
    process_folder(raw, proc)
PYEOF
